# Required — demo will not start without these
ANTHROPIC_AUTH_TOKEN=      # obtain from Anthropic console
KEYCLOAK_ADMIN_PASSWORD=   # Keycloak admin console password

# Optional — safe defaults shown; override if needed
POSTGRES_PASSWORD=****     # localhost Postgres only; demo is a safe default
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
AI_MODEL=glm-5.1
