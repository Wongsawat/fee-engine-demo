{
  "id": "pisp",
  "realm": "pisp",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "clientScopes": [
    {
      "name": "fee-rules:read",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "fee-rules:write",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "ai-rules:read",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "ai-rules:write",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "clients": [
    {
      "clientId": "fee-engine-admin-ui",
      "name": "Fee Engine Admin UI",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      /* true required for ROPC grant_type=password in Task 8 Step 7 smoke test.
         Widened attack surface is acceptable for localhost-only demo — see README security note. */
      "serviceAccountsEnabled": false,
      "redirectUris": ["http://localhost/*"],
      "webOrigins": ["http://localhost"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "fee-rules:read",
        "fee-rules:write",
        "ai-rules:read",
        "ai-rules:write"
      ],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "demo",
      "email": "demo@demo.local",
      "firstName": "Demo",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ]
    }
  ]
}
